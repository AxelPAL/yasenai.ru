# AI Chat Bot backend URL
AI_CHAT_BOT_API_URL=http://localhost:8080/api/v1

# System user credentials for the ai-chat-bot backend
# These are NEVER sent to the frontend
AI_CHAT_BOT_EMAIL=system@example.com
AI_CHAT_BOT_PASSWORD=your-strong-password

# AI Model ID to use for all conversations.
# This is the INTEGER database ID of the model from the ai-chat-bot backend
# (the `id` field from GET /api/v1/models/to-show, NOT the string model_id like "openai/gpt-4o-mini").
AI_MODEL_ID=1

# Session secret - must be at least 32 characters
SESSION_SECRET=change-me-to-a-random-32-character-string-in-production
